---
import "../styles/global.css";
import showroom from "../data/showroom.json";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PromoPopup from "../components/PromoPopup.astro";
import AnnouncementBar from "../components/AnnouncementBar.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = showroom.description,
  ogImage = "/assets/logo.png",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const fullTitle =
  title === "Home"
    ? `Jay Bhavani Furniture — Premium Custom Furniture in Navsari, Surat & Gujarat`
    : `${title} — Jay Bhavani Furniture`;

const currentYear = new Date().getFullYear();
const yearsInBusiness = currentYear - showroom.foundedYear;

// JSON-LD structured data
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": ["FurnitureStore", "ProfessionalService"],
    "@id": Astro.site ? `${Astro.site.toString()}#organization` : undefined,
    name: showroom.name,
    alternateName: showroom.shortName,
    description: showroom.description,
    url: Astro.site?.toString(),
    logo: new URL(showroom.logo, Astro.site).toString(),
    image: new URL(ogImage, Astro.site).toString(),
    telephone: showroom.phoneTel,
    email: showroom.email,
    foundingDate: String(showroom.foundedYear),
    priceRange: "₹₹₹",
    paymentAccepted: "Cash, Credit Card, UPI, Bank Transfer",
    currenciesAccepted: "INR",
    hasMap: showroom.mapUrl,
    sameAs: [
      ...showroom.social.map((s) => s.url),
      showroom.whatsappUrl,
    ],
    knowsAbout: [
      "Custom Furniture",
      "Modular Kitchens",
      "Wardrobes",
      "Living Room Furniture",
      "Bedroom Furniture",
      "Office Furniture",
      "Interior Design",
      "Bespoke Interiors",
    ],
    address: {
      "@type": "PostalAddress",
      streetAddress: showroom.address,
      addressLocality: showroom.city,
      addressRegion: showroom.region,
      postalCode: showroom.postalCode,
      addressCountry: showroom.country,
    },
    geo: {
      "@type": "GeoCoordinates",
      latitude: showroom.geo.latitude,
      longitude: showroom.geo.longitude,
    },
    openingHoursSpecification: showroom.openingHours.map((slot) => ({
      "@type": "OpeningHoursSpecification",
      dayOfWeek: slot.days,
      opens: slot.opens,
      closes: slot.closes,
    })),
    areaServed: [
      { "@type": "City", name: "Navsari" },
      { "@type": "City", name: "Surat" },
      { "@type": "City", name: "Valsad" },
      { "@type": "City", name: "Vapi" },
      { "@type": "City", name: "Bilimora" },
      { "@type": "City", name: "Chikhli" },
      { "@type": "City", name: "Vyara" },
      { "@type": "City", name: "Ahmedabad" },
      { "@type": "City", name: "Vadodara" },
      { "@type": "City", name: "Bharuch" },
      { "@type": "City", name: "Ankleshwar" },
      { "@type": "City", name: "Silvassa" },
      { "@type": "State", name: "Gujarat" },
      { "@type": "State", name: "Maharashtra" },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": Astro.site ? `${Astro.site.toString()}#website` : undefined,
    name: showroom.name,
    alternateName: [showroom.shortName, "Jay Bhavani"],
    description: showroom.description,
    url: Astro.site?.toString(),
    inLanguage: "en-IN",
    publisher: Astro.site
      ? { "@id": `${Astro.site.toString()}#organization` }
      : undefined,
  },
];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow" />
    <meta
      name="google-site-verification"
      content="_kIw5pcOdFq8zh14joaU3TguZ62SNhfO49KSkRuawSs"
    />
    <meta name="p:domain_verify" content="430a070fd54d5e52cf71773e0ac56bac" />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:site_name" content="Jay Bhavani Furniture" />
    <meta property="og:locale" content="en_IN" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Favicon & PWA -->
    <link rel="icon" type="image/png" href="/assets/logo.png" />
    <link rel="apple-touch-icon" href="/assets/logo.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#f59e0b" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    {showroom.googleAnalyticsId && showroom.googleAnalyticsId !== 'G-XXXXXXXXXX' && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${showroom.googleAnalyticsId}`}></script>
        <script is:inline define:vars={{ gaId: showroom.googleAnalyticsId }}>
          window.dataLayer = window.dataLayer || [];
          window.gtag = function gtag(){window.dataLayer.push(arguments);};
          window.gtag('js', new Date());
          // disable automatic pageview so SPA navigation can control pageviews if needed
          window.gtag('config', gaId, { send_page_view: false });
        </script>
      </>
    )}

    <meta name="generator" content={Astro.generator} />
    <slot name="head" />
  </head>
  <body
    class="min-h-screen flex flex-col bg-neutral-50 text-neutral-800 dark:bg-neutral-950 dark:text-neutral-200 antialiased"
  >
    <AnnouncementBar />
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <PromoPopup />
    {showroom.googleAnalyticsId && showroom.googleAnalyticsId !== 'G-XXXXXXXXXX' && (
      <script is:inline>
        // Send an initial page_view for the first full-page load
        (function(){
          if (typeof window !== 'undefined' && typeof window.gtag === 'function') {
            try { window.gtag('event', 'page_view', { page_path: location.pathname, page_title: document.title }); } catch (e) {}
          }
        })();
      </script>
    )}

    <script is:inline>
      // Delegate clicks on elements with `data-analytics-event` to fire consistent events
      (function () {
        function sendEvent(name, props) {
          if (typeof window === 'undefined') return;
          if ('plausible' in window) {
            try { window.plausible(name, { props: props || {} }); } catch (e) {}
            return;
          }
          if ('gtag' in window) {
            try { window.gtag('event', name, props || {}); } catch (e) {}
            return;
          }
          try {
            var isLocal = typeof window !== 'undefined' && (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1' || window.location.hostname === '::1');
            var hasDebugFlag = typeof window !== 'undefined' && window.location && window.location.search && window.location.search.indexOf('debug_analytics') !== -1;
            if (isLocal || hasDebugFlag) {
              console.debug('[analytics] delegated', name, props || {});
            }
          } catch (e) {}
        }

        document.addEventListener('click', function (e) {
          var el = e.target;
          while (el && el.getAttribute && !el.getAttribute('data-analytics-event')) {
            el = el.parentNode;
          }
          if (!el || !el.getAttribute) return;
          var eventName = el.getAttribute('data-analytics-event');
          if (!eventName) return;
          var eventLabel = el.getAttribute('data-analytics-name') || el.textContent || undefined;
          sendEvent(eventName, { event_label: eventLabel });
        }, { passive: true });
      })();
    </script>
  </body>
</html>
