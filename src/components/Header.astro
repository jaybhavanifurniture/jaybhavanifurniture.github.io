---
import showroom from '../data/showroom.json';
import { Icon } from 'astro-icon/components';

const navLinks = [
  { text: 'Collections', href: '/showroom/' },
  { text: 'Bespoke Interiors', href: '/design-build/' },
  { text: 'Architects & Designers', href: '/trade/' },
  { text: 'About', href: '/about/' },
  { text: 'Contact', href: '/contact/' },
  { text: 'Gallery', href: '/gallery/' },
];

const currentPath = Astro.url.pathname;
---

<header
  id="site-header"
  class="sticky top-0 z-50 w-full border-b border-neutral-200/80 bg-neutral-50/90 backdrop-blur-lg dark:border-neutral-800/80 dark:bg-neutral-950/90 transition-all duration-300"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 group" aria-label="Jay Bhavani Furniture — Home">
      <img
        src="/assets/logo.png"
        alt="Jay Bhavani Furniture"
        class="h-9 w-auto transition-transform duration-200 group-hover:scale-105"
        height="36"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
      <span class="text-lg font-semibold tracking-tight text-neutral-900 dark:text-neutral-100">
        Jay Bhavani <span class="text-amber-400">Furniture</span>
      </span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden xl:flex items-center gap-1" aria-label="Main navigation">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'px-2.5 py-2 text-sm font-medium rounded-lg transition-colors duration-200',
            currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
              ? 'text-amber-500 bg-amber-50 dark:bg-amber-500/10'
              : 'text-neutral-600 hover:text-neutral-900 hover:bg-neutral-100 dark:text-neutral-400 dark:hover:text-neutral-100 dark:hover:bg-neutral-800',
          ]}
          aria-current={currentPath === link.href ? 'page' : undefined}
        >
          {link.text}
        </a>
      ))}
    </nav>

    <!-- Desktop CTA -->
    <div class="hidden xl:flex items-center gap-3">

      <a
        href="/estimate/"
        class="inline-flex items-center gap-2 rounded-lg border border-neutral-200 bg-white px-4 py-2 text-sm font-semibold text-neutral-900 shadow-sm hover:bg-neutral-50 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-100 dark:hover:bg-neutral-700 transition-colors duration-200"
        data-analytics-event="cta_click"
        data-analytics-name="free_estimate"
      >
        <Icon name="tabler:calculator" class="h-4 w-4 text-amber-500" />
        Free Estimate
      </a>

      <a
        href={showroom.whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg bg-amber-400 px-4 py-2 text-sm font-semibold text-neutral-900 shadow-sm hover:bg-amber-300 transition-colors duration-200"
        data-analytics-event="cta_click"
        data-analytics-name="whatsapp_cta"
      >
        <Icon name="tabler:brand-whatsapp" class="h-4 w-4" />
        WhatsApp
      </a>
    </div>

    <!-- Mobile CTA & Menu Button -->
    <div class="flex xl:hidden items-center gap-1">
      <a
        href="/estimate/"
        aria-label="Cost Estimator"
        class="rounded-lg p-2 text-amber-600 hover:bg-neutral-100 dark:text-amber-500 dark:hover:bg-neutral-800 transition-colors"
        data-analytics-event="cta_click"
        data-analytics-name="mobile_estimate"
      >
        <Icon name="tabler:calculator" class="h-6 w-6" />
      </a>
      
      <button
        id="mobile-menu-toggle"
        type="button"
        class="rounded-lg p-2 text-neutral-600 hover:bg-neutral-100 dark:text-neutral-400 dark:hover:bg-neutral-800 transition-colors"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <Icon name="tabler:menu-2" class="h-6 w-6 menu-icon" />
        <Icon name="tabler:x" class="h-6 w-6 close-icon hidden" />
      </button>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <div
    id="mobile-menu"
    class="hidden xl:hidden border-t border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-950"
  >
    <nav class="mx-auto max-w-7xl px-4 py-4 sm:px-6" aria-label="Mobile navigation">
      <div class="flex flex-col gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'px-4 py-3 rounded-lg text-base font-medium transition-colors',
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-amber-500 bg-amber-50 dark:bg-amber-500/10'
                : 'text-neutral-700 hover:bg-neutral-100 dark:text-neutral-300 dark:hover:bg-neutral-800',
            ]}
          >
            {link.text}
          </a>
        ))}
      </div>
      <div class="mt-4 border-t border-neutral-200 dark:border-neutral-800 pt-4">
        <a
          href={showroom.whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex w-full items-center justify-center gap-2 rounded-lg bg-amber-400 px-4 py-2.5 text-sm font-semibold text-neutral-900 shadow-sm hover:bg-amber-300 transition-colors"
          data-analytics-event="cta_click"
          data-analytics-name="mobile_whatsapp_cta"
        >
          <Icon name="tabler:brand-whatsapp" class="h-5 w-5" />
          WhatsApp Us
        </a>
      </div>
    </nav>
  </div>
</header>

<!-- Floating WhatsApp button (mobile only) -->
<a
  href={showroom.whatsappUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="fixed bottom-6 right-6 z-50 lg:hidden flex h-14 w-14 items-center justify-center rounded-full bg-green-500 text-white shadow-lg hover:bg-green-600 transition-all duration-200 hover:scale-110"
  aria-label="Chat on WhatsApp"
  data-analytics-event="cta_click"
  data-analytics-name="floating_whatsapp"
>
  <Icon name="tabler:brand-whatsapp" class="h-7 w-7" />
</a>

<script>
  // Mobile menu toggle
  const menuToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = menuToggle?.querySelector('.menu-icon');
  const closeIcon = menuToggle?.querySelector('.close-icon');

  menuToggle?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('hidden') === false;
    menuToggle.setAttribute('aria-expanded', String(isOpen));
    menuIcon?.classList.toggle('hidden', isOpen);
    closeIcon?.classList.toggle('hidden', !isOpen);
  });
</script>
