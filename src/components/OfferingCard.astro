---
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
}

const { title, description, href, icon } = Astro.props;
---

<a
  href={href}
  class="group flex flex-col rounded-xl border border-neutral-200 bg-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-amber-300 dark:border-neutral-800 dark:bg-neutral-900 dark:hover:border-amber-500/50"
>
  <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-amber-50 text-amber-500 transition-colors group-hover:bg-amber-100 dark:bg-amber-500/10 dark:group-hover:bg-amber-500/20">
    <Icon name={icon} class="h-6 w-6" />
  </div>

  <h3 class="mt-4 text-lg font-semibold text-wood-900 dark:text-neutral-100">
    {title}
  </h3>

  <p class="mt-2 flex-1 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400">
    {description}
  </p>

  <div class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-amber-500 group-hover:text-amber-400 transition-colors">
    Learn more
    <Icon name="tabler:arrow-right" class="h-4 w-4 transition-transform group-hover:translate-x-1" />
  </div>
</a>
