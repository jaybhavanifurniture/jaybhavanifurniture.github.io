---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FeatureItem from '../components/FeatureItem.astro';
import CTASection from '../components/CTASection.astro';
import showroom from '../data/showroom.json';

const metadata = {
  title: 'Solid Wood Collections',
  description: 'Premium furniture built in Navsari — living room, bedroom, dining, and office furniture crafted from sustainable materials in our in-house workshop.',
  ogImage: 'https://images.unsplash.com/photo-1555041469-a586c61ea9bc?auto=format&fit=crop&w=2070&q=80',
};

const categories = [
  {
    name: 'Living Room',
    image: 'https://images.unsplash.com/photo-1586023492125-27b2c045efd7?auto=format&fit=crop&w=800&q=80',
    description: 'Coffee tables and TV units in solid timber; sofa frames built on quality engineered cores for lasting shape and comfort.',
  },
  {
    name: 'Bedroom',
    image: 'https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=800&q=80',
    description: 'Beds, wardrobes, dressers, and nightstands built to your room dimensions.',
  },
  {
    name: 'Dining',
    image: 'https://images.unsplash.com/photo-1617806118233-18e1de247200?auto=format&fit=crop&w=800&q=80',
    description: 'Dining tables and chairs that bring families together — sturdy and beautiful.',
  },
  {
    name: 'Office',
    image: 'https://images.unsplash.com/photo-1518455027359-f3f8164ba6bd?auto=format&fit=crop&w=800&q=80',
    description: 'Desks, bookshelves, and filing cabinets for home offices and commercial spaces.',
  },
  {
    name: 'Custom Pieces',
    image: 'https://images.unsplash.com/photo-1588854337236-6889d631faa8?auto=format&fit=crop&w=800&q=80',
    description: 'Anything you need, built to your specs — using the right material for the piece.',
  },
];
---

<BaseLayout title={metadata.title} description={metadata.description} ogImage={metadata.ogImage}>
  <Hero
    title="Solid Wood Collections"
    subtitle="Ready-to-order and customizable furniture from our workshop — for your home."
    imageSrc="https://images.unsplash.com/photo-1555041469-a586c61ea9bc?auto=format&fit=crop&w=2070&q=80"
    imageAlt="Solid wood furniture showroom"
    actions={[
      { text: 'Visit Showroom', href: showroom.mapUrl, icon: 'tabler:map-pin', external: true },
      { text: 'WhatsApp Us', href: showroom.whatsappUrl, icon: 'tabler:brand-whatsapp', variant: 'secondary', external: true },
    ]}
  />

  <!-- Sustainable & Premium Materials -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-wider text-amber-500">Sustainable & Premium Materials</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 sm:text-4xl">
          Furniture that lasts for generations
        </h2>
        <p class="mt-4 text-base leading-relaxed text-neutral-600 dark:text-neutral-400">
          Quality materials and expert craftsmanship ensure your pieces withstand the test of time. Here's what you get when you choose premium timber.
        </p>
      </div>

      <div class="mt-10 grid gap-8 sm:grid-cols-2">
        <FeatureItem
          icon="tabler:clock-check"
          title="Durability"
          description="Premium timber withstands decades of daily use. It can be sanded, refinished, and restored."
        />
        <FeatureItem
          icon="tabler:palette"
          title="Character"
          description="Every piece of wood has unique grain patterns. Your furniture won't look like everyone else's."
        />
        <FeatureItem
          icon="tabler:ruler-measure"
          title="True Customization"
          description="We build to your exact dimensions and finish preferences. Not limited to catalog sizes."
        />
        <FeatureItem
          icon="tabler:leaf"
          title="Sustainability"
          description="Responsibly sourced materials crafted to last a lifetime. Less waste, fewer replacements, better for the environment."
        />
      </div>
    </div>
  </section>

  <!-- What We Make -->
  <section class="bg-neutral-100 py-16 dark:bg-neutral-900 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <p class="text-sm font-semibold uppercase tracking-wider text-amber-500">What We Make</p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 sm:text-4xl">
        Built in our workshop, delivered to your home
      </h2>

      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {categories.map((category) => (
          <div class="group overflow-hidden rounded-xl border border-neutral-200 bg-white dark:border-neutral-800 dark:bg-neutral-900 shadow-sm transition-all duration-300 hover:shadow-lg">
            <div class="overflow-hidden">
              <img
                src={category.image}
                alt={category.name}
                class="h-48 w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
            </div>
            <div class="p-5">
              <h3 class="text-lg font-semibold text-neutral-900 dark:text-neutral-100">
                {category.name}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400">
                {category.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- The JBF Difference -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl bg-wood-600 px-8 py-12 sm:px-12 sm:py-16 text-center">
        <h2 class="text-2xl font-bold text-white sm:text-3xl">
          Crafted with Care
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-wood-200">
          When you buy from JBF, you're collaborating with the people who actually build your furniture. From material selection to final polish, everything happens in our local workshop under careful supervision.
        </p>
        <div class="mt-8">
          <a
            href={showroom.mapUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3 text-base font-semibold text-wood-700 shadow-sm transition-all duration-200 hover:bg-neutral-100 hover:shadow-md"
          >
            Visit Our Showroom
          </a>
        </div>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
