---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProcessStep from '../components/ProcessStep.astro';
import CTASection from '../components/CTASection.astro';
import showroom from '../data/showroom.json';

const metadata = {
  title: 'Bespoke Interiors',
  description: `Complete, bespoke interior execution by Jay Bhavani Furniture. Serving Navsari, Surat, and Valsad with unified workshop control and installation.`,
  ogImage: "https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?auto=format&fit=crop&w=2070&q=80"
};
---

<BaseLayout title={metadata.title} description={metadata.description} ogImage={metadata.ogImage}>
  <Hero
    title="Bespoke Interiors —<br />Design to Installation"
    subtitle="Complete interior design and build, delivered with our design partners — one project, two specialists."
    imageSrc="https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?auto=format&fit=crop&w=2070&q=80"
    imageAlt="Beautifully designed modern living room with solid wood furniture"
    actions={[
      { text: 'Start a Project', href: showroom.whatsappUrl, icon: 'tabler:brand-whatsapp', external: true },
    ]}
  />

  <!-- Our Approach -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-wider text-amber-500">Our Approach</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 sm:text-4xl">
          Visionary design, flawless execution
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-neutral-600 dark:text-neutral-400">
          A truly remarkable interior requires both aesthetic vision and uncompromising craftsmanship.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-neutral-600 dark:text-neutral-400">
          Design by our partner designers. Built and installed by our own workshop. One project, two specialists working as one team — you get a unified experience without either side cutting corners.
        </p>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="bg-neutral-100 py-16 dark:bg-neutral-900 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
        <div>
          <h2 class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 sm:text-4xl">
            How the process works
          </h2>
          <p class="mt-4 text-base leading-relaxed text-neutral-600 dark:text-neutral-400">
            For you, the homeowner, it's seamless. You get a single point of contact, a unified vision, and the assurance that the design you approve can and will be built perfectly.
          </p>
        </div>

        <div class="space-y-2 pl-4 sm:pl-0">
          <ProcessStep
            step={1}
            title="Initial Consultation"
            description="We meet to understand your lifestyle, requirements, budget, and aesthetic vision. This forms the foundation of your custom home."
          />
          <ProcessStep
            step={2}
            title="Design & Planning"
            description="Our partner designer works with you on layouts, material boards, and 3D renders, in close coordination with our workshop — so every design decision is grounded in what can actually be built."
          />
          <ProcessStep
            step={3}
            title="Fabrication"
            description="Once you approve the designs, production begins in our Navsari workshop. We build your kitchens, wardrobes, and statement furniture to our exacting quality standards."
          />
          <ProcessStep
            step={4}
            title="Installation"
            description="Our team installs the finished pieces on-site, managing every detail to ensure the final result matches the initial vision perfectly."
            isLast={true}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Cost Estimator CTA -->
  <section class="py-12 sm:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-amber-50 to-wood-50 p-8 dark:from-amber-900/20 dark:to-wood-900/20 sm:p-12">
        <div class="relative z-10 mx-auto max-w-2xl text-center">
          <p class="text-sm font-semibold uppercase tracking-wider text-amber-600 dark:text-amber-400">
            New Tool
          </p>
          <h2 class="mt-2 text-2xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 sm:text-3xl">
            Get an instant cost estimate
          </h2>
          <p class="mt-3 text-base text-neutral-600 dark:text-neutral-400">
            Our calculator gives you a live cost range based on your home type, area, city, and finish level — no signup required.
          </p>
          <a
            href="/estimate/"
            class="mt-6 inline-flex items-center gap-2 rounded-lg bg-amber-400 px-6 py-3 text-base font-semibold text-neutral-900 shadow-sm transition-all duration-200 hover:bg-amber-300 hover:shadow-md"
          >
            Try the Cost Estimator
            <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <CTASection 
    title="Ready to furnish your entire home?"
    subtitle="Let's chat about your requirements and start bringing your vision to life."
  />
</BaseLayout>
