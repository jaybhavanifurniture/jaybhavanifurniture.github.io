---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { Icon } from 'astro-icon/components';
import showroom from '../../data/showroom.json';
import { getReadingTime } from '../../lib/blog';

// Define static paths for all posts
export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

interface Props {
  post: any;
}

const { post } = Astro.props;
const { Content } = await render(post);

// Fetch all posts to determine related articles
const allPosts = (await getCollection('blog'))
  .filter((p) => !p.data.draft && p.id !== post.id);

// Find related posts (same category first, then share tags, limited to 3)
const relatedPosts = allPosts
  .filter((p) => p.data.category === post.data.category)
  .concat(allPosts.filter((p) => p.data.category !== post.data.category && p.data.tags.some(t => post.data.tags.includes(t))))
  .slice(0, 3);

const readTime = getReadingTime(post.body || '');

const metadata = {
  title: post.data.title,
  description: post.data.description,
  ogImage: post.data.heroImage
};

// URL definitions
const postUrl = new URL(`/blog/${post.id}/`, Astro.site || 'https://jaybhavanifurniture.github.io').toString();
const whatsappShareUrl = `https://api.whatsapp.com/send?text=${encodeURIComponent(`${post.data.title} — Read more at: ${postUrl}`)}`;
const twitterShareUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(postUrl)}`;
const linkedinShareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(postUrl)}`;

// JSON-LD structured data for article rich-snippets
const postJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": `${postUrl}#post`,
  "mainEntityOfPage": postUrl,
  "headline": post.data.title,
  "description": post.data.description,
  "image": new URL(post.data.heroImage, Astro.site || 'https://jaybhavanifurniture.github.io').toString(),
  "datePublished": post.data.pubDate.toISOString(),
  "dateModified": post.data.updatedDate?.toISOString() || post.data.pubDate.toISOString(),
  "author": {
    "@type": "Organization",
    "name": post.data.author,
    "url": Astro.site?.toString() || 'https://jaybhavanifurniture.github.io'
  },
  "publisher": {
    "@type": "FurnitureStore",
    "name": showroom.name,
    "logo": {
      "@type": "ImageObject",
      "url": new URL(showroom.logo, Astro.site || 'https://jaybhavanifurniture.github.io').toString()
    }
  }
};
---

<BaseLayout title={metadata.title} description={metadata.description} ogImage={metadata.ogImage}>
  <!-- Dynamic Post schema -->
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(postJsonLd)} />

  <!-- Scroll reading progress indicator -->
  <div class="fixed top-0 left-0 z-[60] h-[3px] w-full bg-transparent">
    <div id="reading-progress" class="h-full w-0 bg-amber-500 transition-all duration-75"></div>
  </div>

  <article class="py-12 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      
      <!-- Breadcrumbs navigation (SEO & UX friendly) -->
      <nav class="flex text-sm text-neutral-500 dark:text-neutral-400 mb-8" aria-label="Breadcrumb">
        <ol class="flex flex-wrap items-center gap-1 sm:gap-1.5">
          <li>
            <a href="/" class="hover:text-amber-500 transition-colors flex items-center gap-1">
              <Icon name="tabler:home" class="h-3.5 w-3.5" />
              Home
            </a>
          </li>
          <li class="flex items-center">
            <Icon name="tabler:chevron-right" class="h-4 w-4 text-neutral-400" />
            <a href="/blog/" class="ml-1 md:ml-2 hover:text-amber-500 transition-colors">Blog</a>
          </li>
          <li class="flex items-center">
            <Icon name="tabler:chevron-right" class="h-4 w-4 text-neutral-400" />
            <span class="ml-1 md:ml-2 text-neutral-400 dark:text-neutral-500 line-clamp-1">{post.data.category}</span>
          </li>
        </ol>
      </nav>

      <!-- Post Header -->
      <header class="mb-10 text-center sm:text-left">
        <span class="inline-flex items-center rounded-md bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700 dark:bg-amber-950/30 dark:text-amber-400 border border-amber-200/50 dark:border-amber-900/30">
          {post.data.category}
        </span>
        
        <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-neutral-900 dark:text-neutral-100 sm:text-4xl md:text-5xl leading-tight">
          {post.data.title}
        </h1>

        <div class="mt-6 flex flex-wrap items-center justify-center sm:justify-start gap-x-4 gap-y-2 text-sm text-neutral-500 dark:text-neutral-400 border-b border-neutral-200 pb-8 dark:border-neutral-800">
          <div class="flex items-center gap-1.5">
            <span class="h-6 w-6 rounded-full bg-amber-500 text-white flex items-center justify-center text-[10px] font-bold">JBF</span>
            <span class="font-medium text-neutral-700 dark:text-neutral-300">{post.data.author}</span>
          </div>
          <span class="hidden sm:inline text-neutral-300 dark:text-neutral-700">&bull;</span>
          <div class="flex items-center gap-1">
            <Icon name="tabler:calendar" class="h-4 w-4" />
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('en-IN', {
                day: 'numeric',
                month: 'long',
                year: 'numeric'
              })}
            </time>
          </div>
          <span class="hidden sm:inline text-neutral-300 dark:text-neutral-700">&bull;</span>
          <div class="flex items-center gap-1">
            <Icon name="tabler:clock" class="h-4 w-4" />
            <span>{readTime} min read</span>
          </div>
        </div>
      </header>

      <!-- Featured Image -->
      <div class="mb-12 overflow-hidden rounded-2xl shadow-lg border border-neutral-200 dark:border-neutral-800">
        <img
          src={post.data.heroImage}
          alt={post.data.title}
          class="aspect-[21/9] w-full object-cover"
          loading="eager"
          decoding="async"
        />
      </div>

      <!-- Main Layout with share on side and content in center -->
      <div class="lg:grid lg:grid-cols-12 lg:gap-8">
        
        <!-- Left Sidebar: Sticky share options (large screens) -->
        <aside class="hidden lg:col-span-1 lg:block">
          <div class="sticky top-32 flex flex-col items-center gap-4">
            <span class="text-[10px] font-bold uppercase tracking-wider text-neutral-400 dark:text-neutral-500">Share</span>
            
            <a
              href={whatsappShareUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex h-10 w-10 items-center justify-center rounded-full bg-green-50 text-green-600 border border-green-200/50 hover:bg-green-100 transition-colors"
              aria-label="Share on WhatsApp"
            >
              <Icon name="tabler:brand-whatsapp" class="h-5 w-5" />
            </a>

            <a
              href={twitterShareUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex h-10 w-10 items-center justify-center rounded-full bg-blue-50 text-blue-600 border border-blue-200/50 hover:bg-blue-100 transition-colors"
              aria-label="Share on X (Twitter)"
            >
              <Icon name="tabler:brand-x" class="h-4 w-4" />
            </a>

            <a
              href={linkedinShareUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="flex h-10 w-10 items-center justify-center rounded-full bg-indigo-50 text-indigo-600 border border-indigo-200/50 hover:bg-indigo-100 transition-colors"
              aria-label="Share on LinkedIn"
            >
              <Icon name="tabler:brand-linkedin" class="h-5 w-5" />
            </a>

            <button
              type="button"
              id="share-copy-desktop"
              class="relative flex h-10 w-10 items-center justify-center rounded-full bg-neutral-50 text-neutral-600 border border-neutral-200/50 hover:bg-neutral-100 cursor-pointer transition-colors"
              aria-label="Copy Link"
            >
              <Icon name="tabler:link" class="h-5 w-5" />
              <span class="tooltip opacity-0 pointer-events-none absolute left-12 top-1.5 whitespace-nowrap bg-neutral-900 text-white text-[10px] py-1 px-2 rounded transition-opacity duration-200">Copy Link</span>
            </button>
          </div>
        </aside>

        <!-- Main post body -->
        <main class="lg:col-span-11">
          <div class="prose-custom dark:prose-invert">
            <Content />
          </div>

          <!-- Tags list -->
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="mt-12 border-t border-neutral-200 pt-6 dark:border-neutral-800 flex flex-wrap gap-2">
              <span class="text-sm font-semibold text-neutral-500 flex items-center gap-1 py-1 mr-2">
                <Icon name="tabler:tag" class="h-4 w-4" />
                Tags:
              </span>
              {post.data.tags.map((tag: string) => (
                <span class="inline-block rounded-md bg-neutral-100 dark:bg-neutral-800 text-neutral-600 dark:text-neutral-400 px-3 py-1 text-xs font-medium border border-neutral-200/40 dark:border-neutral-700/40">
                  {tag}
                </span>
              ))}
            </div>
          )}

          <!-- Share section for mobile devices -->
          <div class="mt-8 border-t border-neutral-200 pt-6 dark:border-neutral-800 lg:hidden flex items-center gap-4">
            <span class="text-xs font-bold uppercase tracking-wider text-neutral-500">Share:</span>
            <div class="flex items-center gap-2">
              <a
                href={whatsappShareUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="flex h-9 w-9 items-center justify-center rounded-full bg-green-50 text-green-600 border border-green-200/50"
                aria-label="Share on WhatsApp"
              >
                <Icon name="tabler:brand-whatsapp" class="h-5 w-5" />
              </a>

              <a
                href={twitterShareUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="flex h-9 w-9 items-center justify-center rounded-full bg-blue-50 text-blue-600 border border-blue-200/50"
                aria-label="Share on X (Twitter)"
              >
                <Icon name="tabler:brand-x" class="h-4 w-4" />
              </a>

              <a
                href={linkedinShareUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="flex h-9 w-9 items-center justify-center rounded-full bg-indigo-50 text-indigo-600 border border-indigo-200/50"
                aria-label="Share on LinkedIn"
              >
                <Icon name="tabler:brand-linkedin" class="h-5 w-5" />
              </a>

              <button
                type="button"
                id="share-copy-mobile"
                class="relative flex h-9 w-9 items-center justify-center rounded-full bg-neutral-50 text-neutral-600 border border-neutral-200/50 cursor-pointer"
                aria-label="Copy Link"
              >
                <Icon name="tabler:link" class="h-4 w-4" />
                <span class="tooltip opacity-0 pointer-events-none absolute bottom-11 left-1/2 -translate-x-1/2 whitespace-nowrap bg-neutral-900 text-white text-[10px] py-1 px-2 rounded transition-opacity duration-200">Copy Link</span>
              </button>
            </div>
          </div>

          <!-- Author Bio -->
          <div class="mt-12 overflow-hidden rounded-xl border border-neutral-200 bg-neutral-50/50 p-6 dark:border-neutral-800 dark:bg-neutral-900/30 flex flex-col sm:flex-row items-center sm:items-start gap-4">
            <div class="h-14 w-14 rounded-full bg-amber-500 text-white flex items-center justify-center text-lg font-bold shrink-0 shadow-inner">
              JBF
            </div>
            <div class="text-center sm:text-left">
              <h4 class="text-base font-bold text-neutral-900 dark:text-neutral-100">About {post.data.author}</h4>
              <p class="mt-1 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400">
                Crafting custom modular kitchens, solid teak furniture, and space-saving wardrobes in Navsari and Surat since {showroom.foundedYear}. Every guide is vetted by our lead workshop craftsmen to help you design a home that lasts.
              </p>
              <a
                href="/about/"
                class="mt-3 inline-flex items-center gap-1 text-xs font-bold text-amber-500 hover:text-amber-600 dark:hover:text-amber-400"
              >
                Our workshop story &rarr;
              </a>
            </div>
          </div>
          
        </main>
      </div>

      <!-- Related Posts Section (Strong SEO internal linking) -->
      {relatedPosts.length > 0 && (
        <section class="mt-20 border-t border-neutral-200 pt-16 dark:border-neutral-800">
          <h3 class="text-2xl font-bold text-neutral-900 dark:text-neutral-100 mb-8 text-center sm:text-left">
            Recommended Reading
          </h3>
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {relatedPosts.map((relatedPost) => (
              <article class="flex flex-col overflow-hidden rounded-xl border border-neutral-200 bg-white shadow-sm transition-all hover:-translate-y-1 hover:shadow-md dark:border-neutral-800 dark:bg-neutral-900">
                <a href={`/blog/${relatedPost.id}/`} class="relative block aspect-[16/10] overflow-hidden group">
                  <img
                    src={relatedPost.data.heroImage}
                    alt={relatedPost.data.title}
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                    decoding="async"
                  />
                </a>
                <div class="flex flex-1 flex-col justify-between p-5">
                  <div class="flex-1">
                    <span class="inline-block text-[10px] font-bold uppercase tracking-wider text-amber-600 dark:text-amber-500">
                      {relatedPost.data.category}
                    </span>
                    <h4 class="mt-2 text-base font-bold text-neutral-900 dark:text-neutral-100 line-clamp-2">
                      <a href={`/blog/${relatedPost.id}/`} class="hover:text-amber-500 transition-colors">
                        {relatedPost.data.title}
                      </a>
                    </h4>
                  </div>
                  <div class="mt-4 flex items-center justify-between border-t border-neutral-100 pt-3 dark:border-neutral-800 text-[11px] text-neutral-500">
                    <span>{getReadingTime(relatedPost.body || '')} min read</span>
                    <a href={`/blog/${relatedPost.id}/`} class="font-bold text-amber-500 hover:text-amber-600">Read &rarr;</a>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </section>
      )}

    </div>
  </article>
</BaseLayout>

<script>
  // Reading progress indicator
  function setupProgressBar() {
    const progressBar = document.getElementById('reading-progress');
    if (!progressBar) return;

    const handleScroll = () => {
      const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = height > 0 ? (winScroll / height) * 100 : 0;
      progressBar.style.width = scrolled + '%';
    };

    window.addEventListener('scroll', handleScroll, { passive: true });
  }

  // Handle URL copying
  function setupClipboardSharing() {
    const copyBtns = [
      document.getElementById('share-copy-desktop'),
      document.getElementById('share-copy-mobile')
    ];

    copyBtns.forEach(btn => {
      if (!btn) return;
      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(window.location.href);
          const tooltip = btn.querySelector('.tooltip');
          if (tooltip) {
            tooltip.textContent = 'Link Copied!';
            tooltip.classList.remove('opacity-0');
            setTimeout(() => {
              tooltip.textContent = 'Copy Link';
              tooltip.classList.add('opacity-0');
            }, 2000);
          }
        } catch (err) {
          console.error('Failed to copy link: ', err);
        }
      });
    });
  }

  // Bind execution on load
  function initPost() {
    setupProgressBar();
    setupClipboardSharing();
  }

  document.addEventListener('DOMContentLoaded', initPost);
</script>
