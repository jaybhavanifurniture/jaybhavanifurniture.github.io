---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';
import showroom from '../../data/showroom.json';
import { getReadingTime } from '../../lib/blog';

// Fetch all non-draft posts, sorted by date (latest first)
const allPosts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Find featured post (explicitly marked featured, or the newest one)
const featuredPost = allPosts.find((post) => post.data.featured) || allPosts[0];

// Exclude featured post from the main grid list to avoid duplication,
// but keep it if someone filters for it.
const gridPosts = allPosts.filter((post) => post.id !== featuredPost?.id);

// Gather unique categories for the filters
const categories = ['All', ...new Set(allPosts.map((post) => post.data.category))];

const metadata = {
  title: "Official Blog",
  description: "Read expert advice on modular kitchens, solid teak wood furniture care, custom wardrobe designs, and interior trends from Jay Bhavani Furniture in Navsari, Gujarat.",
  ogImage: "https://images.unsplash.com/photo-1556911220-e15b29be8c8f?auto=format&fit=crop&w=1200&q=80"
};

const blogJsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "@id": new URL('/blog/', Astro.site || 'https://jaybhavanifurniture.github.io').toString(),
  "name": "Jay Bhavani Furniture Blog",
  "description": metadata.description,
  "url": new URL('/blog/', Astro.site || 'https://jaybhavanifurniture.github.io').toString(),
  "publisher": {
    "@type": "FurnitureStore",
    "name": showroom.name,
    "logo": new URL(showroom.logo, Astro.site || 'https://jaybhavanifurniture.github.io').toString(),
    "image": new URL(metadata.ogImage, Astro.site || 'https://jaybhavanifurniture.github.io').toString()
  }
};
---

<BaseLayout title={metadata.title} description={metadata.description} ogImage={metadata.ogImage}>
  <!-- Inject Blog JSON-LD Schema to Head slot -->
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(blogJsonLd)} />

  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-wood-50/50 py-16 dark:bg-wood-950/20 border-b border-neutral-200/60 dark:border-neutral-800/50">
    <div class="absolute inset-0 bg-radial-gradient from-amber-500/5 via-transparent to-transparent opacity-70"></div>
    <div class="relative mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
      <span class="inline-flex items-center gap-1.5 rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-800 dark:bg-amber-950/40 dark:text-amber-300">
        <Icon name="tabler:news" class="h-3.5 w-3.5" />
        JBF Workshop Journal
      </span>
      <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-neutral-900 dark:text-neutral-100 sm:text-5xl lg:text-6xl">
        Insights from our workshop.
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-neutral-600 dark:text-neutral-400">
        Over {new Date().getFullYear() - showroom.foundedYear} years of material knowledge, wood care tips, and custom joinery secrets—shared directly by our craftsmen in Navsari.
      </p>
    </div>
  </section>

  <!-- Interactive Controls Section -->
  <section class="sticky top-[61px] z-30 border-b border-neutral-200 bg-white/80 py-4 backdrop-blur-md dark:border-neutral-800 dark:bg-neutral-950/80">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        
        <!-- Search bar -->
        <div class="relative max-w-md w-full">
          <label for="search-blog" class="sr-only">Search articles</label>
          <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-neutral-400 dark:text-neutral-500">
            <Icon name="tabler:search" class="h-5 w-5" />
          </div>
          <input
            type="search"
            id="search-blog"
            placeholder="Search articles by title or keyword..."
            class="block w-full rounded-lg border border-neutral-300 bg-neutral-50 py-2.5 pl-10 pr-4 text-sm text-neutral-900 placeholder-neutral-400 transition-all focus:border-amber-400 focus:bg-white focus:outline-none dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-100 dark:placeholder-neutral-500 dark:focus:bg-neutral-900"
          />
        </div>

        <!-- Category tabs -->
        <div class="flex flex-nowrap md:flex-wrap gap-2 overflow-x-auto pb-2.5 md:pb-0 scrollbar-none" aria-label="Filter by category">
          {categories.map((category) => (
            <button
              type="button"
              data-category={category}
              class:list={[
                'category-btn px-4 py-2 text-xs font-semibold rounded-full border transition-all duration-200 cursor-pointer whitespace-nowrap',
                category === 'All'
                  ? 'bg-amber-500 text-white border-amber-500 shadow-sm shadow-amber-500/10'
                  : 'bg-neutral-100 text-neutral-600 border-neutral-200 hover:border-neutral-300 dark:bg-neutral-800 dark:text-neutral-300 dark:border-neutral-700 dark:hover:border-neutral-600'
              ]}
            >
              {category}
            </button>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- Blog Content Section -->
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      
      <!-- Featured Post (Latest or Selected) -->
      {featuredPost && (
        <div id="featured-section" class="post-card mb-16 overflow-hidden rounded-2xl border border-neutral-200/80 bg-white shadow-md dark:border-neutral-800/80 dark:bg-neutral-900 transition-all hover:shadow-lg lg:grid lg:grid-cols-12"
             data-category={featuredPost.data.category}
             data-title={featuredPost.data.title}
             data-description={featuredPost.data.description}>
          <div class="relative min-h-[300px] lg:col-span-7">
            <img
              src={featuredPost.data.heroImage}
              alt={featuredPost.data.title}
              class="absolute inset-0 h-full w-full object-cover"
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-neutral-950/50 via-transparent to-transparent lg:hidden"></div>
          </div>
          
          <div class="flex flex-col justify-between p-6 sm:p-8 lg:col-span-5 lg:p-10">
            <div>
              <div class="flex items-center gap-3">
                <span class="inline-flex items-center rounded-md bg-amber-50 px-2.5 py-1 text-xs font-medium text-amber-700 dark:bg-amber-950/30 dark:text-amber-400 border border-amber-200/50 dark:border-amber-900/30">
                  {featuredPost.data.category}
                </span>
                <span class="text-xs text-neutral-500 dark:text-neutral-400 flex items-center gap-1">
                  <Icon name="tabler:calendar" class="h-3.5 w-3.5" />
                  {featuredPost.data.pubDate.toLocaleDateString('en-IN', {
                    day: 'numeric',
                    month: 'short',
                    year: 'numeric'
                  })}
                </span>
              </div>
              
              <h2 class="mt-4 text-2xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 sm:text-3xl">
                <a href={`/blog/${featuredPost.id}/`} class="hover:text-amber-500 transition-colors">
                  {featuredPost.data.title}
                </a>
              </h2>
              
              <p class="mt-4 text-base leading-relaxed text-neutral-600 dark:text-neutral-400">
                {featuredPost.data.description}
              </p>
            </div>
            
            <div class="mt-8 flex items-center justify-between border-t border-neutral-100 pt-6 dark:border-neutral-800">
              <div class="flex items-center gap-2">
                <span class="text-xs font-semibold text-neutral-700 dark:text-neutral-300">
                  {featuredPost.data.author}
                </span>
                <span class="text-xs text-neutral-400">&bull;</span>
                <span class="text-xs text-neutral-500 dark:text-neutral-400 flex items-center gap-1">
                  <Icon name="tabler:clock" class="h-3.5 w-3.5" />
                  {getReadingTime(featuredPost.body || '')} min read
                </span>
              </div>
              
              <a
                href={`/blog/${featuredPost.id}/`}
                class="inline-flex items-center gap-1.5 text-sm font-bold text-amber-500 hover:text-amber-600 dark:hover:text-amber-400 group/link"
              >
                Read Article
                <Icon name="tabler:arrow-right" class="h-4 w-4 transition-transform duration-200 group-hover/link:translate-x-1" />
              </a>
            </div>
          </div>
        </div>
      )}

      <!-- Normal Posts Grid -->
      <div id="posts-grid" class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {gridPosts.map((post) => (
          <article
            class="post-card flex flex-col overflow-hidden rounded-xl border border-neutral-200 bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-md dark:border-neutral-800 dark:bg-neutral-900"
            data-category={post.data.category}
            data-title={post.data.title}
            data-description={post.data.description}
          >
            <!-- Card Image -->
            <a href={`/blog/${post.id}/`} class="relative block aspect-[16/10] overflow-hidden group">
              <img
                src={post.data.heroImage}
                alt={post.data.title}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
                decoding="async"
              />
            </a>

            <!-- Card Content -->
            <div class="flex flex-1 flex-col justify-between p-6">
              <div class="flex-1">
                <div class="flex items-center gap-3">
                  <span class="inline-flex items-center rounded-md bg-neutral-100 px-2 py-0.5 text-xs font-semibold text-neutral-600 dark:bg-neutral-800 dark:text-neutral-300 border border-neutral-200/50 dark:border-neutral-700/50">
                    {post.data.category}
                  </span>
                  <span class="text-xs text-neutral-500 dark:text-neutral-400 flex items-center gap-1">
                    <Icon name="tabler:calendar" class="h-3.5 w-3.5" />
                    {post.data.pubDate.toLocaleDateString('en-IN', {
                      day: 'numeric',
                      month: 'short',
                      year: 'numeric'
                    })}
                  </span>
                </div>
                
                <h3 class="mt-4 text-xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 line-clamp-2">
                  <a href={`/blog/${post.id}/`} class="hover:text-amber-500 transition-colors">
                    {post.data.title}
                  </a>
                </h3>
                
                <p class="mt-3 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400 line-clamp-3">
                  {post.data.description}
                </p>
              </div>

              <!-- Card Footer -->
              <div class="mt-6 flex items-center justify-between border-t border-neutral-100 pt-4 dark:border-neutral-800">
                <span class="text-xs text-neutral-500 dark:text-neutral-400 flex items-center gap-1">
                  <Icon name="tabler:clock" class="h-3.5 w-3.5" />
                  {getReadingTime(post.body || '')} min read
                </span>
                
                <a
                  href={`/blog/${post.id}/`}
                  class="inline-flex items-center gap-1 text-xs font-bold text-amber-500 hover:text-amber-600 dark:hover:text-amber-400 group/link"
                >
                  Read Article
                  <Icon name="tabler:chevron-right" class="h-3.5 w-3.5 transition-transform duration-200 group-hover/link:translate-x-0.5" />
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- No Results State -->
      <div id="no-results" class="hidden text-center py-20 border border-dashed border-neutral-200 rounded-2xl dark:border-neutral-800">
        <Icon name="tabler:news" class="mx-auto h-12 w-12 text-neutral-400 dark:text-neutral-600" />
        <h3 class="mt-4 text-lg font-bold text-neutral-900 dark:text-neutral-100">No articles found</h3>
        <p class="mt-2 text-sm text-neutral-500 dark:text-neutral-400">Try adjusting your search keywords or choosing another category.</p>
        <button
          type="button"
          id="reset-search"
          class="mt-6 rounded-lg bg-amber-500 px-4 py-2 text-xs font-semibold text-white shadow-sm hover:bg-amber-600 transition-colors"
        >
          Reset Filters
        </button>
      </div>

    </div>
  </section>

  <!-- CTA Box -->
  <section class="bg-wood-50 dark:bg-wood-950/20 py-16 border-t border-neutral-200/60 dark:border-neutral-800/50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="relative overflow-hidden rounded-2xl bg-neutral-900 px-6 py-12 shadow-xl dark:bg-neutral-900/60 sm:px-12 sm:py-16">
        <div class="absolute inset-0 bg-gradient-to-r from-wood-800/30 to-amber-600/10 mix-blend-multiply"></div>
        
        <div class="relative mx-auto max-w-3xl text-center">
          <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
            Want to bring these ideas into your home?
          </h2>
          <p class="mx-auto mt-4 max-w-xl text-lg text-neutral-300">
            Get in touch with our design experts in Navsari for a free custom consultation.
          </p>
          <div class="mt-8 flex flex-col justify-center gap-4 sm:flex-row">
            <a
              href="/estimate/"
              class="inline-flex items-center justify-center gap-2 rounded-lg bg-white px-5 py-3 text-sm font-semibold text-neutral-900 shadow-sm hover:bg-neutral-50 transition-colors"
            >
              <Icon name="tabler:calculator" class="h-4.5 w-4.5 text-amber-500" />
              Calculate Kitchen/Wardrobe Costs
            </a>
            <a
              href={showroom.whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 rounded-lg bg-amber-400 px-5 py-3 text-sm font-semibold text-neutral-900 shadow-sm hover:bg-amber-300 transition-colors"
            >
              <Icon name="tabler:brand-whatsapp" class="h-4.5 w-4.5" />
              Consult via WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Setup interactive clientside filters and searches
  function initFilters() {
    const searchInput = document.getElementById('search-blog') as HTMLInputElement | null;
    const categoryButtons = document.querySelectorAll<HTMLElement>('.category-btn');
    const postCards = document.querySelectorAll<HTMLElement>('.post-card');
    const noResults = document.getElementById('no-results');
    const resetBtn = document.getElementById('reset-search');
    const featuredSection = document.getElementById('featured-section');

    let activeCategory = 'all';
    let searchQuery = '';

    function filterPosts() {
      let visibleCount = 0;

      postCards.forEach((card) => {
        const category = card.getAttribute('data-category')?.toLowerCase() || '';
        const title = card.getAttribute('data-title')?.toLowerCase() || '';
        const description = card.getAttribute('data-description')?.toLowerCase() || '';

        const matchesCategory = activeCategory === 'all' || category === activeCategory;
        const matchesSearch = title.includes(searchQuery) || description.includes(searchQuery);

        if (matchesCategory && matchesSearch) {
          card.classList.remove('hidden');
          // If the featured card is visible, show it as a flex/grid block
          if (card.id === 'featured-section') {
            card.style.display = 'grid';
          } else {
            card.style.display = 'flex';
          }
          visibleCount++;
        } else {
          card.classList.add('hidden');
          card.style.display = 'none';
        }
      });

      if (noResults) {
        if (visibleCount === 0) {
          noResults.classList.remove('hidden');
        } else {
          noResults.classList.add('hidden');
        }
      }
    }

    searchInput?.addEventListener('input', (e) => {
      searchQuery = (e.target as HTMLInputElement).value.toLowerCase().trim();
      filterPosts();
    });

    categoryButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        // Update active visual button classes
        categoryButtons.forEach((b) => {
          b.classList.remove('bg-amber-500', 'text-white', 'border-amber-500', 'shadow-sm', 'shadow-amber-500/10');
          b.classList.add('bg-neutral-100', 'text-neutral-600', 'border-neutral-200', 'dark:bg-neutral-800', 'dark:text-neutral-300', 'dark:border-neutral-700');
        });

        btn.classList.remove('bg-neutral-100', 'text-neutral-600', 'border-neutral-200', 'dark:bg-neutral-800', 'dark:text-neutral-300', 'dark:border-neutral-700');
        btn.classList.add('bg-amber-500', 'text-white', 'border-amber-500', 'shadow-sm', 'shadow-amber-500/10');

        const rawCat = btn.getAttribute('data-category') || 'All';
        activeCategory = rawCat === 'All' ? 'all' : rawCat.toLowerCase();
        filterPosts();
      });
    });

    // Reset buttons
    const handleReset = () => {
      if (searchInput) searchInput.value = '';
      searchQuery = '';
      activeCategory = 'all';

      categoryButtons.forEach((btn) => {
        const isAll = btn.getAttribute('data-category') === 'All';
        if (isAll) {
          btn.classList.remove('bg-neutral-100', 'text-neutral-600', 'border-neutral-200', 'dark:bg-neutral-800', 'dark:text-neutral-300', 'dark:border-neutral-700');
          btn.classList.add('bg-amber-500', 'text-white', 'border-amber-500', 'shadow-sm', 'shadow-amber-500/10');
        } else {
          btn.classList.remove('bg-amber-500', 'text-white', 'border-amber-500', 'shadow-sm', 'shadow-amber-500/10');
          btn.classList.add('bg-neutral-100', 'text-neutral-600', 'border-neutral-200', 'dark:bg-neutral-800', 'dark:text-neutral-300', 'dark:border-neutral-700');
        }
      });

      filterPosts();
    };

    resetBtn?.addEventListener('click', handleReset);
  }

  // Handle Astro page transitions / page load
  document.addEventListener('DOMContentLoaded', initFilters);
</script>
