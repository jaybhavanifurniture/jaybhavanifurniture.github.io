---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProcessStep from '../components/ProcessStep.astro';
import showroom from '../data/showroom.json';

const metadata = {
  title: 'Your Fabrication Partner',
  description: 'JBF is the reliable fabrication partner for interior designers and architects in Navsari. We build custom furniture to your exact specifications.',
};
---

<BaseLayout title={metadata.title} description={metadata.description}>
  <Hero
    title="Your Fabrication Partner"
    subtitle="When a project needs a real statement piece — a custom table, elegant doors, or a feature unit — that's us. We build to your exact specifications."
    imageSrc="https://images.unsplash.com/photo-1555041469-a586c61ea9bc?auto=format&fit=crop&w=2070&q=80"
    imageAlt="Architectural plans on a custom wood table"
    actions={[
      { text: 'Discuss a Project', href: showroom.whatsappUrl, icon: 'tabler:brand-whatsapp', external: true },
      { text: 'Email Specs', href: `mailto:${showroom.email}`, icon: 'tabler:mail', variant: 'secondary' },
    ]}
  />

  <!-- What we build -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
        <div>
          <p class="text-sm font-semibold uppercase tracking-wider text-amber-500">For the Trade</p>
          <h2 class="mt-2 text-3xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 sm:text-4xl">
            Specialized architectural fabrication.
          </h2>
          <div class="mt-6 space-y-4 text-base leading-relaxed text-neutral-600 dark:text-neutral-400">
            <p>
              As an interior designer or architect, you already manage complex projects. You need a reliable fabrication partner who can execute your vision flawlessly.
            </p>
            <p>
              JBF specializes strictly in premium carpentry. When your design calls for sustainable materials, complex joinery, or bespoke wooden elements, we step in.
            </p>
          </div>
        </div>
        
        <div class="grid grid-cols-2 gap-4">
          <div class="space-y-4">
            <div class="rounded-xl bg-neutral-100 p-6 dark:bg-neutral-900">
              <h3 class="font-semibold text-neutral-900 dark:text-neutral-100">Statement Tables</h3>
              <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-400">Conference tables, 10-seater dining, live edges.</p>
            </div>
            <div class="rounded-xl bg-neutral-100 p-6 dark:bg-neutral-900">
              <h3 class="font-semibold text-neutral-900 dark:text-neutral-100">Custom Doors</h3>
              <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-400">Main entrance, pooja room doors, carved panels.</p>
            </div>
          </div>
          <div class="space-y-4 pt-8">
            <div class="rounded-xl bg-neutral-100 p-6 dark:bg-neutral-900">
              <h3 class="font-semibold text-neutral-900 dark:text-neutral-100">Feature Units</h3>
              <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-400">Slatted partitions, solid wood consoles, bar units.</p>
            </div>
            <div class="rounded-xl bg-neutral-100 p-6 dark:bg-neutral-900">
              <h3 class="font-semibold text-neutral-900 dark:text-neutral-100">Bespoke Seating</h3>
              <p class="mt-2 text-sm text-neutral-600 dark:text-neutral-400">Custom sofas, lounge chairs, built-in wooden benches.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Cost Transparency -->
  <section class="bg-neutral-100 py-16 dark:bg-neutral-900 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-wider text-amber-500">Cost Transparency</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 sm:text-4xl">
          Investing in quality materials
        </h2>
        <p class="mt-4 text-lg text-neutral-600 dark:text-neutral-400">
          We want to preempt budget mismatches. Premium carpentry is an investment in sustainable materials and time.
        </p>
      </div>

      <div class="mx-auto mt-12 grid max-w-4xl gap-6 sm:grid-cols-3">
        <div class="rounded-xl border border-neutral-200 bg-white p-6 shadow-sm dark:border-neutral-800 dark:bg-neutral-950">
          <div class="text-2xl font-bold text-amber-500">1. Material</div>
          <p class="mt-3 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400">
            We choose materials to match the piece — solid teak, sheesham, or rosewood where strength and character matter most; quality engineered cores where stability matters more than mass. What we won't use, regardless of budget pressure, is particle board or cheap composite filler.
          </p>
        </div>
        <div class="rounded-xl border border-neutral-200 bg-white p-6 shadow-sm dark:border-neutral-800 dark:bg-neutral-950">
          <div class="text-2xl font-bold text-amber-500">2. Labor</div>
          <p class="mt-3 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400">
            Solid wood requires skilled carpentry, not just assembly. Cutting, planning, joinery, and sanding are done by hand by experienced artisans.
          </p>
        </div>
        <div class="rounded-xl border border-neutral-200 bg-white p-6 shadow-sm dark:border-neutral-800 dark:bg-neutral-950">
          <div class="text-2xl font-bold text-amber-500">3. Time</div>
          <p class="mt-3 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400">
            Proper finishing takes time. Sealing, polishing, and curing cannot be rushed if the piece is to last for decades without warping.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How we work -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
        <div>
          <h2 class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 sm:text-4xl">
            Our process with designers
          </h2>
          <p class="mt-4 text-base leading-relaxed text-neutral-600 dark:text-neutral-400">
            We respect your relationship with your client. We act as your fabrication wing, ensuring your designs are executed exactly as specified. We fabricate to your specification only — we don't pursue your clients directly for our own interiors work.
          </p>
          <div class="mt-8">
            <a
              href={showroom.whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg bg-amber-400 px-6 py-3 text-base font-semibold text-neutral-900 shadow-sm transition-all duration-200 hover:bg-amber-300 hover:shadow-md"
            >
              Send us your drawings
            </a>
          </div>
        </div>

        <div class="space-y-2 pl-4 sm:pl-0">
          <ProcessStep
            step={1}
            title="Design Review & Feasibility"
            description="Send us your CAD drawings or sketches. We'll review the structural feasibility for solid wood and suggest joinery methods."
          />
          <ProcessStep
            step={2}
            title="Estimation & Material Selection"
            description="We provide a detailed estimate based on cubic feet of wood required, labor, and finishing. We can assist in timber selection."
          />
          <ProcessStep
            step={3}
            title="Fabrication in Our Workshop"
            description="Your pieces are built in our Navsari workshop. You are welcome to visit during the build to inspect progress."
          />
          <ProcessStep
            step={4}
            title="Delivery & Installation"
            description="We handle the final delivery and on-site assembly, ensuring everything fits perfectly into your larger interior project."
            isLast={true}
          />
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
