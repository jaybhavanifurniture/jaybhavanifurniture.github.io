---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
---

<BaseLayout title="Page Not Found" description="The page you are looking for could not be found.">
  <section class="flex flex-col items-center justify-center py-24 sm:py-32 bg-neutral-50 dark:bg-neutral-950 text-center px-4">
    <div class="inline-flex h-20 w-20 items-center justify-center rounded-full bg-amber-100 text-amber-500 mb-8 dark:bg-amber-500/10">
      <Icon name="tabler:error-404" class="h-10 w-10" />
    </div>
    
    <h1 class="text-4xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 sm:text-5xl mb-4">
      Page Not Found
    </h1>
    
    <p class="text-lg text-neutral-600 dark:text-neutral-400 max-w-md mx-auto mb-10">
      We're sorry, the page you requested could not be found. It might have been removed, had its name changed, or is temporarily unavailable.
    </p>
    
    <div class="flex flex-col sm:flex-row items-center gap-4">
      <a
        href="/"
        class="inline-flex items-center justify-center gap-2 rounded-lg bg-amber-400 px-6 py-3 text-base font-semibold text-neutral-900 shadow-sm transition-all duration-200 hover:bg-amber-300 hover:shadow-md w-full sm:w-auto"
      >
        <Icon name="tabler:arrow-left" class="h-5 w-5" />
        Back to Home
      </a>
      
      <a
        href="/contact"
        class="inline-flex items-center justify-center gap-2 rounded-lg border border-neutral-300 bg-white px-6 py-3 text-base font-semibold text-neutral-900 shadow-sm transition-all duration-200 hover:bg-neutral-50 hover:shadow-md dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-100 dark:hover:bg-neutral-800 w-full sm:w-auto"
      >
        Contact Us
      </a>
    </div>
  </section>
</BaseLayout>
